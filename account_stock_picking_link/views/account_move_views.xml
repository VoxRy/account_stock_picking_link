<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_stock_link" model="ir.ui.view">
        <field name="name">account.move.form.inherit.stock.link</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_picking"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-truck"
                        attrs="{'invisible': [('picking_count', '=', 0)]}">
                    <field name="picking_count" widget="statinfo" string="Transferler"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Transferler" name="picking_page">
                    <field name="picking_ids" nolabel="1" attrs="{'readonly': [('state', 'not in', ('draft', 'posted'))]}">
                        <tree string="Transferler">
                            <field name="company_id" invisible="1"/>
                            <field name="name" string="Transfer"/>
                            <field name="partner_id" string="İlgili Kişi"/>
                            <field name="origin" string="Kaynak Belge"/>
                            <field name="scheduled_date" string="Planlanan Tarih"/>
                            <field name="state" string="Durum"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

